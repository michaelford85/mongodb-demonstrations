# MongoDB Atlas — operational tier
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority
DB_NAME=atlas_databricks_demo

# AWS S3 — the handoff point between Atlas (operational) and Databricks (analytics).
#
# If AWS_S3_BUCKET is left blank the export script writes to ./_s3_export/ locally
# and clearly labels it as a stand-in for S3. This keeps the demo runnable for
# anyone who does not have AWS credentials configured. The downstream analytics
# step reads from whichever location was used.
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_PREFIX=atlas-exports/

# Optional: number of synthetic orders to generate (default 250)
NUM_ORDERS=250
