# MongoDB Atlas connection string for a cluster that already has the sample data loaded.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority

# Key vault namespace used by both demos.
KEY_VAULT_NAMESPACE=encryption.__keyVault

# Local KMS master key settings.
LOCAL_MASTER_KEY_PATH=.keys/local-master-key.bin

# Optional: set this if PyMongo cannot automatically locate the Automatic Encryption Shared Library.
# CRYPT_SHARED_LIB_PATH=/absolute/path/to/mongo_crypt_v1.dylib

# Optional overrides for the demo scripts.
CSFLE_KEY_ALT_NAME=demo-csfle-key
QE_KEY_ALT_NAME=demo-qe-key
QE_RANGE_MIN=0
QE_RANGE_MAX=20000
QE_RANGE_SPARSITY=1
