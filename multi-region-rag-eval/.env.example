# Connection strings (no credentials are committed; populate locally).
# Postgres on Amazon RDS with the pgvector extension already enabled.
PG_CONN_STR=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# MongoDB Atlas cluster connection string.
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/?retryWrites=true&w=majority

# Target database / collection / table names.
MONGO_DB=routing_demo
MONGO_COLLECTION=accounts
PG_TABLE=accounts

# Vector dimensions (1024 mirrors voyage-3, 2000 mirrors voyage-3-large).
EMBED_DIM=1024

# Number of synthetic rows to generate (allowed range: 1000 - 17000).
ROW_COUNT=5000

# Name of the Atlas Vector Search index defined in mongodb/atlas_index.json.
ATLAS_VECTOR_INDEX=accounts_vector_idx
