# Connection strings (no credentials are committed; populate locally).
# Postgres on Amazon RDS with the pgvector extension already enabled.
PG_CONN_STR=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# MongoDB Atlas cluster connection string.
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/?retryWrites=true&w=majority

# Target database / collection / table names.
MONGO_DB=routing_demo
MONGO_COLLECTION=accounts
PG_TABLE=accounts

# Voyage AI API key. Used client-side for both the Postgres and the
# MongoDB ingest/search paths so the two backends share an embedding
# pipeline (same model, same input_type, same output_dimension).
VOYAGE_API_KEY=

# Voyage AI embedding model. The same model name is substituted into
# mongodb/atlas_index.json at index-creation time so both backends share an
# embedding space. Flexible-dimension models include voyage-3-large,
# voyage-3.5, voyage-3.5-lite, voyage-4-large, voyage-4, voyage-4-lite, and
# voyage-code-3.
VOYAGE_MODEL=voyage-3-large

# Vector dimensions. Must match the model's output_dimension. voyage-3-large
# and the voyage-4-* family support 256, 512, 1024 (default), and 2048;
# voyage-3 / voyage-3.5 produce 1024; voyage-3-lite / voyage-3.5-lite produce
# 512.
EMBED_DIM=1024

# Number of synthetic rows to generate (allowed range: 1000 - 17000).
ROW_COUNT=5000

# Name of the Atlas Vector Search index defined in mongodb/atlas_index.json.
ATLAS_VECTOR_INDEX=accounts_vector_idx

# Name of the Atlas Search (BM25 / Lucene) index defined in
# mongodb/atlas_search_index.json. Used by mongodb/hybrid_search.py to add a
# lexical-similarity arm alongside $vectorSearch for fuzzy-string queries.
ATLAS_SEARCH_INDEX=accounts_bm25_idx

# Voyage AI reranker model. Used by --rerank in compare.py and by
# mongodb/hybrid_search.py. rerank-2.5 is the current top-quality reranker;
# rerank-2.5-lite is the budget tier with similar quality on shorter texts.
VOYAGE_RERANK_MODEL=rerank-2.5
