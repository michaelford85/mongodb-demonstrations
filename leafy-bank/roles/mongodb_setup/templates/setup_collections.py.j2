#!/usr/bin/env python3
"""
Generated by Ansible — creates required MongoDB databases and collections
for the selected Leafy Bank services.
"""
from pymongo import MongoClient
from pymongo.errors import CollectionInvalid

MONGODB_URI = "{{ mongodb_uri }}"

# (database_name, collection_name) pairs to ensure exist.
COLLECTIONS = [
{% for entry in _db_collections %}
{% for collection in entry.collections %}
    ("{{ entry.database }}", "{{ collection }}"),
{% endfor %}
{% endfor %}
]

def main():
    client = MongoClient(MONGODB_URI)
    for db_name, coll_name in COLLECTIONS:
        db = client[db_name]
        if coll_name in db.list_collection_names():
            print(f"Exists:  {db_name}.{coll_name}")
        else:
            try:
                db.create_collection(coll_name)
                print(f"Created: {db_name}.{coll_name}")
            except CollectionInvalid:
                print(f"Exists:  {db_name}.{coll_name}")
    client.close()

if __name__ == "__main__":
    main()
