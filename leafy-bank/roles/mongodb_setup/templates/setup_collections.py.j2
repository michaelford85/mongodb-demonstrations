#!/usr/bin/env python3
"""
Generated by Ansible — creates required MongoDB databases, collections, and
Atlas Vector Search indexes for the selected Leafy Bank services.
"""
from pymongo import MongoClient
from pymongo.errors import CollectionInvalid, OperationFailure

MONGODB_URI = "{{ mongodb_uri }}"

# (database_name, collection_name) pairs to ensure exist.
COLLECTIONS = [
{% for entry in _db_collections %}
{% for collection in entry.collections %}
    ("{{ entry.database }}", "{{ collection }}"),
{% endfor %}
{% endfor %}
]

# Vector Search indexes to create.
# Each entry: (database, collection, index_name, vector_field, dimensions, similarity, filter_fields)
VECTOR_SEARCH_INDEXES = [
{% for svc in setup_services %}
{% if svc.vector_search_indexes is defined %}
{% for idx in svc.vector_search_indexes %}
    {
        "database":    "{{ idx.database }}",
        "collection":  "{{ idx.collection }}",
        "index_name":  "{{ idx.index_name }}",
        "vector_field": "{{ idx.vector_field }}",
        "dimensions":  {{ idx.dimensions | default(1024) }},
        "similarity":  "{{ idx.similarity | default('cosine') }}",
        "filter_fields": {{ idx.filter_fields | default([]) | tojson }},
    },
{% endfor %}
{% endif %}
{% endfor %}
]

def ensure_collections(client):
    for db_name, coll_name in COLLECTIONS:
        db = client[db_name]
        if coll_name in db.list_collection_names():
            print(f"Exists:  {db_name}.{coll_name}")
        else:
            try:
                db.create_collection(coll_name)
                print(f"Created: {db_name}.{coll_name}")
            except CollectionInvalid:
                print(f"Exists:  {db_name}.{coll_name}")

def ensure_vector_search_indexes(client):
    for idx in VECTOR_SEARCH_INDEXES:
        db   = client[idx["database"]]
        coll = db[idx["collection"]]

        fields = [
            {
                "path": idx["vector_field"],
                "type": "vector",
                "numDimensions": idx["dimensions"],
                "similarity": idx["similarity"],
            }
        ]
        for fp in idx["filter_fields"]:
            fields.append({"path": fp, "type": "filter"})

        index_config = {
            "name": idx["index_name"],
            "type": "vectorSearch",
            "definition": {"fields": fields},
        }

        try:
            coll.create_search_index(index_config)
            print(f"VSIndex created:  {idx['database']}.{idx['collection']} -> {idx['index_name']}")
        except OperationFailure as e:
            if e.code == 68:  # IndexAlreadyExists
                print(f"VSIndex exists:   {idx['database']}.{idx['collection']} -> {idx['index_name']}")
            else:
                print(f"VSIndex ERROR:    {idx['database']}.{idx['collection']} -> {idx['index_name']}: {e}")
        except Exception as e:
            print(f"VSIndex ERROR:    {idx['database']}.{idx['collection']} -> {idx['index_name']}: {e}")

def main():
    client = MongoClient(MONGODB_URI)
    ensure_collections(client)
    ensure_vector_search_indexes(client)
    client.close()

if __name__ == "__main__":
    main()
