# Generated by Ansible — do not edit manually.
# Backend service URLs are derived from the ports in group_vars/all.yml.
#
# NEXT_PUBLIC_* vars are resolved in the browser (host machine) → use localhost.
# INTERNAL_*    vars are resolved inside the Next.js Docker container → use
#               host.docker.internal so server-side proxy routes can reach the
#               host-exposed ports of other containers.
{% macro port(svc_name) %}{{ (leafy_bank_services | selectattr('name', 'equalto', svc_name) | first).port }}{% endmacro %}

