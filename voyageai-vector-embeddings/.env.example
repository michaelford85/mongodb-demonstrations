# VoyageAI
VOYAGE_API_KEY=your_voyage_api_key_here
VOYAGE_MODEL=voyage-3.5
VOYAGE_RERANK_MODEL=voyage-rerank-2
EMBEDDING_DIM=1024
BATCH_SIZE=128

# MongoDB Atlas
DB_NAME=ecommerce_demo
COLLECTION_NAME=products

# X.509 certificate auth (recommended for Atlas)
MONGODB_URI="mongodb+srv://your-cluster.mongodb.net/?authSource=%24external&authMechanism=MONGODB-X509&retryWrites=true&w=majority"
MONGODB_CERT="/path/to/your/cert.pem"

# OR username/password auth — remove the two lines above and use:
# MONGODB_URI="mongodb+srv://username:password@your-cluster.mongodb.net/?retryWrites=true&w=majority"

# App settings
QUERY_LIMIT=10
