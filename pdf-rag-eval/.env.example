# Copy to .env and fill in real values. .env is gitignored.

# ---- Voyage AI --------------------------------------------------------------
VOYAGE_API_KEY=
# Default is voyage-4-large at 1024 dims (matches the Cosmos vector policy).
# Other valid models: voyage-4, voyage-4-lite, voyage-3-large, voyage-3.5.
# VOYAGE_MODEL=voyage-4-large
# EMBED_DIM=1024

# ---- Azure Cosmos DB (for NoSQL) -------------------------------------------
# Pull these from terraform output in ../cosmosdb-cluster-provisioning:
#   terraform output -raw endpoint
#   terraform output -raw primary_key
COSMOS_ENDPOINT=
COSMOS_KEY=
# COSMOS_DATABASE=ragdb
# COSMOS_CONTAINER=chunks
# COSMOS_VECTOR_PATH=/embedding
# COSMOS_PARTITION_KEY_PATH=/document_id

# ---- MongoDB Atlas ----------------------------------------------------------
# Point at an existing Atlas cluster (M10+ required for Vector Search).
MONGODB_URI=
# MONGO_DB=pdf_rag_eval
# MONGO_COLLECTION=chunks
# ATLAS_VECTOR_INDEX=chunks_vector_idx

# ---- Azure Blob Storage -----------------------------------------------------
# Pull from terraform output in ./infra:
#   terraform output -raw connection_string
AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=pdfs

# ---- PDF generation and chunking -------------------------------------------
# PDF_COUNT=20
# CHUNK_CHAR_SIZE=1500
# CHUNK_CHAR_OVERLAP=200
