# Copy to .env and fill in real values. .env is gitignored.

# ---- Azure auth -------------------------------------------------------------
# Subscription Terraform should target.
ARM_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# ---- Storage account --------------------------------------------------------
# Globally unique, 3-24 chars, lowercase letters and digits ONLY (no hyphens).
TF_VAR_storage_account_name=changeme0pdfrageval

# Optional overrides; defaults are in variables.tf.
# TF_VAR_location=eastus
# TF_VAR_resource_group_name=pdf-rag-eval-rg
# TF_VAR_container_name=pdfs

# ---- Network allow-list -----------------------------------------------------
# Your laptop's public IPv4 address. The outer single quotes are
# REQUIRED so bash preserves the inner double quotes when setup.sh
# sources this file.
TF_VAR_allowed_ip_addresses='["203.0.113.42"]'
