# Copy this file to .env and fill in the values, then `source .env`
# before running setup.sh / teardown.sh.
#
# AWS programmatic access is assumed to be already configured via
# `aws configure` (i.e. ~/.aws/credentials, an SSO profile, or the
# instance role). We only set the region here; credentials are not
# stored in this file.

# --- AWS ---------------------------------------------------------------
export AWS_REGION=us-east-1
export AWS_DEFAULT_REGION=us-east-1
# Optional: pick a named profile from ~/.aws/credentials.
# export AWS_PROFILE=default

# --- Terraform variables ----------------------------------------------
# Terraform automatically reads any environment variable prefixed with
# TF_VAR_ and maps it to the matching `variable` block.

# Cluster naming
export TF_VAR_cluster_identifier=pgvector-demo
export TF_VAR_db_name=appdb

# Master credentials. Use a strong, unique password of at least 16
# characters. Do NOT commit your filled-in .env.
export TF_VAR_db_admin_username=appadmin
export TF_VAR_db_admin_password=REPLACE_WITH_A_STRONG_PASSWORD_16CHARS

# Network access. Restrict to your own IP. The Terraform validation
# rejects 0.0.0.0/0 to prevent accidental exposure.
# Tip: curl -s https://checkip.amazonaws.com to get your current public IP.
export TF_VAR_allowed_cidr_blocks='["YOUR.PUBLIC.IP.ADDR/32"]'

# Optional overrides --------------------------------------------------
# export TF_VAR_engine_version=16.4
# export TF_VAR_instance_class=db.t4g.medium
# export TF_VAR_publicly_accessible=true
# export TF_VAR_backup_retention_days=1
