# ─────────────────────────────────────────────
# MongoDB Atlas API Credentials
# Create a programmatic API key at:
#   Atlas UI → Access Manager → API Keys
# The key needs the "Organization Project Creator" role (minimum).
# ─────────────────────────────────────────────
ATLAS_PUBLIC_KEY=<your-public-api-key>
ATLAS_PRIVATE_KEY=<your-private-api-key>

# ─────────────────────────────────────────────
# Existing Atlas Project
# Found in Atlas UI → your project → Settings → Project ID
# ─────────────────────────────────────────────
ATLAS_PROJECT_ID=<your-existing-project-id>

# ─────────────────────────────────────────────
# Cluster Identity
# ─────────────────────────────────────────────
CLUSTER_NAME=demo-cluster

# ─────────────────────────────────────────────
# Cloud Provider
# Accepted values: AWS | GCP | AZURE
# All regions in CLUSTER_REGIONS must belong to this provider.
# ─────────────────────────────────────────────
CLUSTER_CLOUD_PROVIDER=AWS

# ─────────────────────────────────────────────
# Instance size — M10 is the smallest dedicated tier.
# Dedicated tiers required for multi-region and most Atlas features.
# Examples: M10, M20, M30, M40
# ─────────────────────────────────────────────
CLUSTER_INSTANCE_SIZE=M30

# MongoDB major version
MONGODB_VERSION=8.0

# ─────────────────────────────────────────────
# Region topology
#
# CLUSTER_NUM_REGIONS — how many regions the cluster spans.
# Used for documentation and validated by deploy.sh against CLUSTER_REGIONS.
#
# CLUSTER_REGIONS — JSON array, one object per region.
#   region_name     : Atlas region identifier (see Atlas UI or docs)
#   electable_nodes : nodes in this region that can be elected primary
#   priority        : 7 = primary-eligible (highest), 6, 5 … for secondaries
#
# Total electable_nodes across ALL regions should be an odd number (3 or 5).
# Priority 7 must appear exactly once (the primary region).
#
# Single-region example (3-node replica set):
#   CLUSTER_REGIONS='[{"region_name":"US_EAST_1","electable_nodes":3,"priority":7}]'
#
# Three-region example (Milan primary, Mumbai + US East secondaries — 7 nodes total):
#   CLUSTER_REGIONS='[{"region_name":"EU_SOUTH_1","electable_nodes":3,"priority":7},{"region_name":"AP_SOUTH_1","electable_nodes":2,"priority":6},{"region_name":"US_EAST_1","electable_nodes":2,"priority":5}]'
# ─────────────────────────────────────────────
CLUSTER_NUM_REGIONS=1
CLUSTER_REGIONS='[{"region_name":"US_EAST_1","electable_nodes":3,"priority":7}]'

# ─────────────────────────────────────────────
# Atlas Search dedicated nodes
# 0 = Atlas Search runs on the electable nodes (shared, no extra cost).
# > 0 = dedicated Search nodes are provisioned (requires M10+).
# ─────────────────────────────────────────────
CLUSTER_SEARCH_NODES=0

# ─────────────────────────────────────────────
# Admin database user
# This user is created with the atlasAdmin role.
# ─────────────────────────────────────────────
DB_ADMIN_USER=admin
DB_ADMIN_PASSWORD=<choose-a-strong-password>
