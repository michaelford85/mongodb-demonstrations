# Copy to .env and fill in real values. .env is gitignored.

# ---- Azure auth -------------------------------------------------------------
# Subscription Terraform should target. Get yours with:
#   az account show --query id -o tsv
ARM_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# ---- Cosmos account ---------------------------------------------------------
# Globally unique, 3-44 chars, lowercase letters/digits/hyphens. Pick
# something like "<yourname>-cosmos-vector-demo".
TF_VAR_account_name=changeme-cosmos-vector-demo

# Optional overrides; defaults are in variables.tf.
# TF_VAR_location=eastus
# TF_VAR_resource_group_name=cosmos-vector-demo-rg
# TF_VAR_database_name=ragdb
# TF_VAR_container_name=chunks
# TF_VAR_vector_dimensions=1024
# TF_VAR_vector_index_type=diskANN
# TF_VAR_autoscale_max_throughput=1000

# ---- Network allow-list -----------------------------------------------------
# Your laptop's public IPv4 address (no CIDR). Find it with:
#   curl -s https://checkip.amazonaws.com
# Pass as a Terraform list literal in JSON form. The outer single quotes
# are REQUIRED so bash preserves the inner double quotes when setup.sh
# sources this file; without them Terraform sees malformed HCL and
# crashes during `terraform init`.
TF_VAR_allowed_ip_addresses='["203.0.113.42"]'
