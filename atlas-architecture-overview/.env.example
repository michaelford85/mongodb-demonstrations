# ─────────────────────────────────────────────
# Atlas Architecture Overview — shared connection settings
#
# All demos in this folder load .env from here, so credentials live in one
# place. Provision the clusters with the sibling Terraform folders first:
#   - Replica set (Topics 1 & 2) : ../atlas-cluster-provisioning
#   - Sharded cluster (Topic 3)  : ../atlas-sharded-cluster-provisioning
# Grab each cluster's SRV connection string from `terraform output` or the
# Atlas UI and paste it below.
# ─────────────────────────────────────────────

# ── Replica set cluster (Topics 1 & 2) ──────
# Use a multi-region replica set for Topic 2 to show geographic distribution.
REPLICASET_URI=mongodb+srv://<user>:<password>@<replicaset-host>/?retryWrites=true&w=majority

# ── Sharded cluster (Topic 3) ───────────────
# Use the GEOSHARDED cluster (Zone 1 / Zone 2) for the zone-sharding demo.
SHARDED_URI=mongodb+srv://<user>:<password>@<sharded-host>/?retryWrites=true&w=majority

# ── Demo database / collection names ────────
# All demos write into this database; teardown drops it.
DEMO_DB=architecture_demo
