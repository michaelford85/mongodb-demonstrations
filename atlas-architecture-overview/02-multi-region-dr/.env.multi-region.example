# ─────────────────────────────────────────────
# Topic 2 — Multi-region DR
#
# Copy the values you want into ../atlas-cluster-provisioning/.env, then run
# `./deploy.sh` in that folder to (re-)provision the replica set across three
# regions. Topic 2's scripts read REPLICASET_URI from the shared .env at the
# root of this folder, so you only need to update the SRV string there after
# the cluster comes up.
#
# This template overrides just the region-topology variables; copy your other
# settings (API keys, project id, cluster name, etc.) from the existing
# atlas-cluster-provisioning/.env.example file.
# ─────────────────────────────────────────────

# Three-region replica set: US East primary, Ireland + Mumbai secondaries.
# 5 electable nodes total (odd, so elections always quorum cleanly).
CLUSTER_NUM_REGIONS=3
CLUSTER_REGIONS='[{"region_name":"US_EAST_1","electable_nodes":2,"priority":7},{"region_name":"EU_WEST_1","electable_nodes":2,"priority":6},{"region_name":"AP_SOUTH_1","electable_nodes":1,"priority":5}]'
