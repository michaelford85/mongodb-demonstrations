# Regular cluster connection string — queries live (hot) data only
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority

DB_NAME=sample_mflix
COLLECTION_NAME=movies

# Atlas Data Federation connection string — queries live + archived (cold) data
# Atlas UI → Data Federation → your federated instance → Connect
# Only needed for query_demo.py after archiving has run.
FEDERATED_URI=mongodb+srv://<username>:<password>@<federated-host>/?ssl=true&authSource=admin

# Atlas Admin API credentials (same values as atlas-cluster-provisioning)
ATLAS_PUBLIC_KEY=<your-public-api-key>
ATLAS_PRIVATE_KEY=<your-private-api-key>
ATLAS_PROJECT_ID=<your-existing-project-id>
CLUSTER_NAME=<your-cluster-name>

# Archive cutoff: movies with a 'released' date older than this many days will be archived.
# 9000 days ≈ year 2001  |  7300 days ≈ year 2004  |  5475 days ≈ year 2009
ARCHIVE_EXPIRE_AFTER_DAYS=9000
