# Regular cluster connection string — queries live (hot) data only
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority

DB_NAME=sample_mflix
COLLECTION_NAME=movies

# Atlas Data Federation connection string — queries live + archived (cold) data
# Atlas UI → Data Federation → your federated instance → Connect
# Only needed for query_demo.py after archiving has run.
FEDERATED_URI=mongodb://<username>:<password>@<federated-host>/?ssl=true&authSource=admin

# Atlas Admin API credentials (same values as atlas-cluster-provisioning)
ATLAS_PUBLIC_KEY=<your-public-api-key>
ATLAS_PRIVATE_KEY=<your-private-api-key>
ATLAS_PROJECT_ID=<your-existing-project-id>
CLUSTER_NAME=<your-cluster-name>

# Archive ID — only needed for teardown_archive.py when multiple archive rules exist
# on the same cluster and you need to target a specific one. Leave blank normally.
# Find the ID by running teardown_archive.py with no ARCHIVE_ID set — it will list them.
ARCHIVE_ID=

# Archive cutoff: movies with a year strictly less than this value will be archived.
# 2001 leaves ~15,000 pre-2001 films in cold storage and ~8,000 newer films on the live cluster.
ARCHIVE_CUTOFF_YEAR=2001

# Data process region: where Atlas stores and queries the archived data.
# Required for multi-region clusters — Atlas cannot auto-determine the region.
# Use any one region your cluster already spans.
# Cloud provider: AWS | GCP | AZURE
# Region: the Atlas region string for that provider (e.g. US_EAST_1, EU_WEST_1)
ARCHIVE_CLOUD_PROVIDER=AWS
ARCHIVE_REGION=US_EAST_1
