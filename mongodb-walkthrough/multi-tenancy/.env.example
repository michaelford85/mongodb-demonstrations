# Cluster connection string — used by all scripts for data operations
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/?retryWrites=true&w=majority

# Atlas Admin API credentials — required for database user creation/deletion
# (same values used by atlas-cluster-provisioning and online-archive)
ATLAS_PUBLIC_KEY=<your-public-api-key>
ATLAS_PRIVATE_KEY=<your-private-api-key>
ATLAS_PROJECT_ID=<your-existing-project-id>

# Passwords for the scoped tenant database users created by setup_tenants.py.
# These users are granted read-only access to their respective tenant database
# only. Used by demo.py to demonstrate credential-level RBAC isolation.
CLASSICFLIX_PASSWORD=<password-for-classicflix-app-user>
MILLENNIUMSTREAM_PASSWORD=<password-for-millenniumstream-app-user>
MODERNPLEX_PASSWORD=<password-for-modernplex-app-user>
