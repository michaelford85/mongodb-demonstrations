# ─────────────────────────────────────────────
# MongoDB Atlas API Credentials
# Create a programmatic API key at:
#   Atlas UI → Access Manager → API Keys
# The key needs the "Organization Project Creator" role (minimum).
# ─────────────────────────────────────────────
ATLAS_PUBLIC_KEY=<your-public-api-key>
ATLAS_PRIVATE_KEY=<your-private-api-key>

# ─────────────────────────────────────────────
# Existing Atlas Project
# Found in Atlas UI → your project → Settings → Project ID
# ─────────────────────────────────────────────
ATLAS_PROJECT_ID=<your-existing-project-id>

# ─────────────────────────────────────────────
# Cluster Identity
# ─────────────────────────────────────────────
CLUSTER_NAME=demo-sharded-cluster

# ─────────────────────────────────────────────
# Cluster type
#   SHARDED    — all shards share one zone. Atlas requires every shard to
#                have the same region topology (same regions, priorities,
#                node counts). Use this when you want multiple shards in
#                the same region(s).
#   GEOSHARDED — each shard is placed in its own zone (Zone 1, Zone 2, …),
#                so shards may use different regions. Use this when you
#                want shard 1 in (e.g.) EU and shard 2 in US.
# ─────────────────────────────────────────────
CLUSTER_TYPE=SHARDED

# ─────────────────────────────────────────────
# Cloud Provider
# Accepted values: AWS | GCP | AZURE
# All regions in CLUSTER_SHARDS must belong to this provider.
# ─────────────────────────────────────────────
CLUSTER_CLOUD_PROVIDER=AWS

# ─────────────────────────────────────────────
# Instance size — M30 is the smallest tier that supports sharded clusters.
# This size applies to every shard. Examples: M30, M40, M50.
# ─────────────────────────────────────────────
CLUSTER_INSTANCE_SIZE=M30

# MongoDB major version
MONGODB_VERSION=8.0

# ─────────────────────────────────────────────
# Shard topology
#
# CLUSTER_NUM_SHARDS — how many shards the cluster contains.
# Used for documentation and validated by deploy.sh against CLUSTER_SHARDS.
#
# CLUSTER_SHARDS — JSON array, one object per shard. Each shard is itself
# a replica set, so each shard carries its own region_configs list.
#
# Each region_config object:
#   region_name     : Atlas region identifier (see Atlas UI or docs)
#   electable_nodes : nodes in this region that can be elected primary
#   priority        : 7 = primary-eligible (highest), 6, 5 … for secondaries
#
# Per shard:
# - Total electable_nodes across all region_configs should be odd (3 or 5).
# - Priority 7 must appear exactly once (the primary region for that shard).
#
# When CLUSTER_TYPE=SHARDED every shard's region_configs MUST be identical.
# Set CLUSTER_TYPE=GEOSHARDED to allow shards to differ in regions.
#
# (SHARDED) Two-shard example, both shards co-located in US East — simplest, cheapest:
#   CLUSTER_SHARDS='[
#     {"region_configs":[{"region_name":"US_EAST_1","electable_nodes":3,"priority":7}]},
#     {"region_configs":[{"region_name":"US_EAST_1","electable_nodes":3,"priority":7}]}
#   ]'
#
# (GEOSHARDED) Two-shard geo-distributed example — shard 1 in EU, shard 2 in US:
#   CLUSTER_SHARDS='[
#     {"region_configs":[{"region_name":"EU_WEST_1","electable_nodes":3,"priority":7}]},
#     {"region_configs":[{"region_name":"US_EAST_1","electable_nodes":3,"priority":7}]}
#   ]'
#
# (GEOSHARDED) Two-shard, each shard multi-region — shard 1 spans EU, shard 2 spans US+APAC:
#   CLUSTER_SHARDS='[
#     {"region_configs":[
#       {"region_name":"EU_WEST_1","electable_nodes":2,"priority":7},
#       {"region_name":"EU_SOUTH_1","electable_nodes":1,"priority":6}
#     ]},
#     {"region_configs":[
#       {"region_name":"US_EAST_1","electable_nodes":2,"priority":7},
#       {"region_name":"AP_SOUTH_1","electable_nodes":1,"priority":6}
#     ]}
#   ]'
# ─────────────────────────────────────────────
CLUSTER_NUM_SHARDS=2
CLUSTER_SHARDS='[{"region_configs":[{"region_name":"US_EAST_1","electable_nodes":3,"priority":7}]},{"region_configs":[{"region_name":"US_EAST_1","electable_nodes":3,"priority":7}]}]'

# ─────────────────────────────────────────────
# Atlas Search dedicated nodes
# 0 = Atlas Search runs on the electable nodes (shared, no extra cost).
# > 0 = dedicated Search nodes are provisioned (requires M10+).
# ─────────────────────────────────────────────
CLUSTER_SEARCH_NODES=0

# ─────────────────────────────────────────────
# Compute Auto-Scale
# Required by Atlas Automated Embedding (autoEmbed vector search indexes);
# Atlas refuses to create an autoEmbed index without it. Defaults to true.
#
# CLUSTER_COMPUTE_MAX_INSTANCE_SIZE: ceiling for scale-up. Leave blank to
# pin max = CLUSTER_INSTANCE_SIZE — that enables the feature without
# actually scaling, which is the cheapest configuration that still
# satisfies the autoEmbed prerequisite. Set it (e.g. M40) only if you
# want Atlas to scale up under load.
# ─────────────────────────────────────────────
CLUSTER_COMPUTE_AUTOSCALE_ENABLED=true
CLUSTER_COMPUTE_MAX_INSTANCE_SIZE=

# ─────────────────────────────────────────────
# Admin database user
# This user is created with the atlasAdmin role.
# ─────────────────────────────────────────────
DB_ADMIN_USER=admin
DB_ADMIN_PASSWORD=<choose-a-strong-password>
