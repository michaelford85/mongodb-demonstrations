# ─────────────────────────────────────────────
# GCP Authentication
# Path to a service-account key JSON file with permissions to create
# Spanner instances/databases, create service accounts, and grant IAM
# (e.g. roles/spanner.admin + roles/iam.serviceAccountAdmin +
#  roles/iam.serviceAccountKeyAdmin on the project).
#
# This is the *provisioning* identity. The harness identity is created
# by Terraform and emitted as an output.
# ─────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=<absolute-path-to-provisioner-sa-key.json>

# ─────────────────────────────────────────────
# GCP Project
# Found in the GCP Console → Project picker → Project ID (not name).
# ─────────────────────────────────────────────
GCP_PROJECT_ID=<your-gcp-project-id>

# ─────────────────────────────────────────────
# GCP Region
# Drives the Spanner instance config: regional-${GCP_REGION}.
# Examples: us-central1, us-east1, europe-west1, asia-southeast1.
# For multi-region configs (nam3, eur3, nam-eur-asia1, …) edit
# terraform/main.tf and set the config string directly.
# ─────────────────────────────────────────────
GCP_REGION=us-central1

# ─────────────────────────────────────────────
# Spanner Instance
# instance_id: 2-30 chars, must match [a-z][-a-z0-9]*[a-z0-9]
# ─────────────────────────────────────────────
SPANNER_INSTANCE_ID=demo-instance

# ─────────────────────────────────────────────
# Spanner Database
# database_id: 2-30 chars, must match [a-z][-_a-z0-9]*[a-z0-9]
# ─────────────────────────────────────────────
SPANNER_DATABASE_ID=demo-db

# ─────────────────────────────────────────────
# Processing Units
# 100 PU is the minimum and the smallest billable unit.
# 1000 PU == 1 node. Must be a multiple of 100 below 1000, then
# a multiple of 1000 above that (Spanner enforces this server-side).
#
# 100 PU is the cheapest regional configuration.
# ─────────────────────────────────────────────
SPANNER_PROCESSING_UNITS=100

# ─────────────────────────────────────────────
# Database Dialect
# Accepted values: GOOGLE_STANDARD_SQL | POSTGRESQL
# ─────────────────────────────────────────────
SPANNER_DIALECT=GOOGLE_STANDARD_SQL
